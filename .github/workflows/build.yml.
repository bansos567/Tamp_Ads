name: Build Rush Extension

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout Repository
      uses: actions/checkout@v3

    - name: Set up JDK 11
      uses: actions/setup-java@v3
      with:
        java-version: '11'
        distribution: 'adopt'

    - name: Install Rush CLI
      run: |
        wget https://github.com/shreyashsaitwal/rush-cli/releases/download/v1.2.5/rush-1.2.5-linux-x64.zip
        unzip rush-1.2.5-linux-x64.zip
        sudo mv rush /usr/local/bin/
        sudo chmod +x /usr/local/bin/rush

    - name: Build Extension
      run: rush build

    - name: Upload AIX Artifact
      uses: actions/upload-artifact@v3
      with:
        name: Hasil-Extension-AIX
        path: out/*.aix
